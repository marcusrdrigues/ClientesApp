{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "sqlproj: Build DBCliente",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"c:/workspace/ClientesApp/DBCliente/DBCliente.sqlproj"
			],
			"problemMatcher": "$sqlproj-problem-matcher",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Builds the DBCliente SQL project"
		},
		{
			"label": "sqlproj: Build localhost",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"c:/workspace/ClientesApp/localhost/localhost.sqlproj"
			],
			"problemMatcher": "$sqlproj-problem-matcher",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "Builds the localhost SQL project"
		}
	]
}